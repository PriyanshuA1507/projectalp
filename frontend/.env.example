# Backend API (IQAC / APAR authenticated routes)
VITE_BASEURL=http://localhost:8000/api/v1

# Hugging Face — used client-side on Feedback Analysis page only
# Create a token with "Inference Providers" permission:
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
VITE_HUGGINGFACE_API_KEY=hf_your_token_here

# Router API (replaces deprecated api-inference.huggingface.co)
# VITE_HF_ROUTER_URL=https://router.huggingface.co/v1

# Optional: override default chat model
# VITE_HF_MODEL=Qwen/Qwen2.5-7B-Instruct-1M
