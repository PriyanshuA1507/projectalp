# Backend API (IQAC / APAR authenticated routes)
VITE_BASEURL=http://localhost:8000/api/v1

# Hugging Face - required by Feedback Analysis page
# Create a fine-grained token with "Make calls to Inference Providers" permission:
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
VITE_HUGGINGFACE_API_KEY=hf_your_token_here

# Router API for Hugging Face Inference Providers chat completions
# VITE_HF_ROUTER_URL=https://router.huggingface.co/v1

# Optional: override the default fallback list with one model
# VITE_HF_MODEL=Qwen/Qwen3-4B-Thinking-2507

# Optional: or provide a comma-separated fallback list
# VITE_HF_MODELS=Qwen/Qwen3-4B-Thinking-2507,Qwen/Qwen2.5-7B-Instruct-1M,google/gemma-2-2b-it
